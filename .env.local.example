NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Vercel Cron — auto-sync Operations data every 6 hours (generate a random secret)
CRON_SECRET=

# Operations > Orders Metabase JSON feed (optional until Orders sync is enabled)
METABASE_OPERATIONS_ORDERS_URL=

# Password reset emails (Resend). Required for email delivery.
# Get your API key at https://resend.com/api-keys
# Sandbox (no domain setup): RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev

PORTAL_NAME=360 Services Portal

# Admin login (access all roles). Optional.
PORTAL_ADMIN_EMAIL=admin@example.com
PORTAL_ADMIN_PASSWORD=your-secure-admin-password

